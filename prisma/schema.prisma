// CRM schema for Next.js + PostgreSQL
// Money is stored as Decimal(12,2). Tax rates as Decimal(5,4) (e.g. 0.1000 = 10% GST).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------- Enums ----------

enum UserRole {
  ADMIN
  MANAGER
  MEMBER
}

enum CompanyStatus {
  LEAD
  PROSPECT
  ACTIVE
  INACTIVE
}

enum DealStage {
  QUALIFICATION
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum ProductType {
  PRODUCT
  SERVICE
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  VOID
}

enum PaymentMethod {
  BANK_TRANSFER
  CARD
  CASH
  CHEQUE
  OTHER
}

enum ActivityAction {
  CREATED
  UPDATED
  DELETED
}

// ---------- Core CRM ----------

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      UserRole @default(MEMBER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedCompanies Company[]
  ownedDeals     Deal[]
  quotes         Quote[]
  invoices       Invoice[]
}

// Generic audit trail for every entity. entityType/entityId identify the
// record; userId is nullable now (no auth yet) but ready for it later.
model Activity {
  id         String         @id @default(cuid())
  entityType String
  entityId   String
  action     ActivityAction
  summary    String?
  // Neon Auth user id (neon_auth."user".id) of the actor; null for system
  // entries. Deliberately not a Prisma relation: login accounts live in the
  // neon_auth schema, so actor names are resolved in lib/activity, not via a FK.
  userId     String?
  createdAt  DateTime       @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

model Company {
  id       String        @id @default(cuid())
  name     String
  website  String?
  email    String?
  phone    String?
  industry String?
  status   CompanyStatus @default(LEAD)

  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  postcode     String?
  country      String?

  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts    Contact[]
  deals       Deal[]
  projects    Project[]
  quotes      Quote[]
  invoices    Invoice[]
  portalUsers PortalUser[]

  @@index([ownerId])
  @@index([status])
}

model Contact {
  id        String  @id @default(cuid())
  firstName String
  lastName  String
  email     String?
  phone     String?
  jobTitle  String?
  isPrimary Boolean @default(false)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deals    Deal[]
  quotes   Quote[]
  invoices Invoice[]

  @@index([companyId])
  @@index([email])
}

model Deal {
  id                String    @id @default(cuid())
  title             String
  value             Decimal   @db.Decimal(12, 2)
  stage             DealStage @default(QUALIFICATION)
  expectedCloseDate DateTime?
  closedAt          DateTime?

  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  ownerId   String?
  owner     User?    @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([contactId])
  @@index([ownerId])
  @@index([stage])
}

// ---------- Projects & Time Tracking ----------

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  hourlyRate  Decimal?      @db.Decimal(10, 2)
  budget      Decimal?      @db.Decimal(12, 2)
  startDate   DateTime?
  endDate     DateTime?

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks       Task[]
  timeEntries TimeEntry[]

  @@index([companyId])
  @@index([status])
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  dueDate     DateTime?

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Neon Auth user id of the assignee (login users, not the CRM User model).
  // Stored as a plain id since neon_auth.user isn't a Prisma model here.
  assigneeId String?

  // Set when a "due soon" reminder email has been sent, so the reminder cron
  // notifies each task at most once.
  dueSoonNotifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  timeEntries TimeEntry[]

  @@index([projectId])
  @@index([assigneeId])
}

model TimeEntry {
  id              String   @id @default(cuid())
  description     String?
  date            DateTime
  durationMinutes Int
  billable        Boolean  @default(true)
  hourlyRate      Decimal? @db.Decimal(10, 2)
  invoiced        Boolean  @default(false)

  // Neon Auth user id of the person who logged the time (login users, not the
  // CRM User model). Stored as a plain id since neon_auth.user isn't a Prisma
  // model here — same convention as Task.assigneeId.
  userId String

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  // Set when this entry is rolled up onto a billed line item.
  invoiceLineItemId String?
  invoiceLineItem   InvoiceLineItem? @relation(fields: [invoiceLineItemId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([projectId])
  @@index([taskId])
  @@index([date])
  @@index([invoiceLineItemId])
}

// ---------- Catalog & Tax ----------

model TaxRate {
  id        String  @id @default(cuid())
  name      String
  rate      Decimal @db.Decimal(5, 4) // e.g. 0.1000 = 10% GST
  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products         Product[]
  quoteLineItems   QuoteLineItem[]
  invoiceLineItems InvoiceLineItem[]
}

model Product {
  id          String      @id @default(cuid())
  name        String
  description String?
  sku         String?     @unique
  type        ProductType @default(SERVICE)
  unitPrice   Decimal     @db.Decimal(12, 2)

  taxRateId String?
  taxRate   TaxRate? @relation(fields: [taxRateId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quoteLineItems   QuoteLineItem[]
  invoiceLineItems InvoiceLineItem[]

  @@index([taxRateId])
}

// ---------- Quotes ----------

model Quote {
  id         String      @id @default(cuid())
  number     String      @unique
  status     QuoteStatus @default(DRAFT)
  issueDate  DateTime    @default(now())
  expiryDate DateTime?
  notes      String?

  // Denormalised totals, recalculated from line items on write.
  subtotal  Decimal @default(0) @db.Decimal(12, 2)
  taxAmount Decimal @default(0) @db.Decimal(12, 2)
  total     Decimal @default(0) @db.Decimal(12, 2)

  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  ownerId   String?
  owner     User?    @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lineItems QuoteLineItem[]
  invoice   Invoice? // populated when this quote is converted to an invoice

  @@index([companyId])
  @@index([contactId])
  @@index([ownerId])
  @@index([status])
}

model QuoteLineItem {
  id          String  @id @default(cuid())
  description String
  quantity    Decimal @default(1) @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(12, 2)
  lineTotal   Decimal @db.Decimal(12, 2)
  taxable     Boolean @default(true) // whether 10% GST applies to this line
  position    Int     @default(0)

  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  taxRateId String?
  taxRate   TaxRate? @relation(fields: [taxRateId], references: [id], onDelete: SetNull)

  @@index([quoteId])
  @@index([productId])
  @@index([taxRateId])
}

// ---------- Invoices ----------

model Invoice {
  id        String        @id @default(cuid())
  number    String        @unique
  status    InvoiceStatus @default(DRAFT)
  issueDate DateTime      @default(now())
  dueDate   DateTime?
  notes     String?

  // Denormalised totals, recalculated from line items / payments on write.
  subtotal   Decimal @default(0) @db.Decimal(12, 2)
  taxAmount  Decimal @default(0) @db.Decimal(12, 2)
  total      Decimal @default(0) @db.Decimal(12, 2)
  amountPaid Decimal @default(0) @db.Decimal(12, 2)

  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  ownerId   String?
  owner     User?    @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  // Optional link back to the quote this invoice was generated from.
  quoteId String? @unique
  quote   Quote?  @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lineItems InvoiceLineItem[]
  payments  Payment[]

  @@index([companyId])
  @@index([contactId])
  @@index([ownerId])
  @@index([status])
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  description String
  quantity    Decimal @default(1) @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(12, 2)
  lineTotal   Decimal @db.Decimal(12, 2)
  taxable     Boolean @default(true) // whether 10% GST applies to this line
  position    Int     @default(0)

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  taxRateId String?
  taxRate   TaxRate? @relation(fields: [taxRateId], references: [id], onDelete: SetNull)

  // Time entries rolled up into this line item (for time-based billing).
  timeEntries TimeEntry[]

  @@index([invoiceId])
  @@index([productId])
  @@index([taxRateId])
}

model Payment {
  id        String        @id @default(cuid())
  amount    Decimal       @db.Decimal(12, 2)
  method    PaymentMethod @default(BANK_TRANSFER)
  paidAt    DateTime      @default(now())
  reference String?
  notes     String?

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([invoiceId])
}

// Grants a Neon Auth login (neon_auth."user".id) access to one company's client
// portal. Owned by the CRM — the website portal resolves a signed-in user's
// company through this link. authUserId is stored as a plain id (not a relation)
// because login accounts live in the neon_auth schema, which isn't modelled here.
model PortalUser {
  id         String @id @default(cuid())
  authUserId String @unique

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model BusinessConfig {
  id                   String  @id @default(cuid())
  businessName         String
  businessEmail        String
  businessPhone        String
  businessAddressLine1 String?
  businessAddressLine2 String?
  businessCity         String?
  businessState        String?
  businessPostcode     String?
  abn                  String?
  payTo                String?
  bsb                  String?
  accountNumber        String?
  bankName             String?
}

// Per-user email notification preferences. Keyed by the Neon Auth user id
// (neon_auth.user, not the CRM User model) — same convention as Task.assigneeId.
model NotificationSettings {
  id     String @id @default(cuid())
  userId String @unique

  // Task/todo emails
  taskAssigned Boolean @default(true)
  taskDueSoon  Boolean @default(true)

  // Invoice emails
  invoiceSent    Boolean @default(true)
  invoiceOverdue Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Per-automation configuration for the Workflows module. One row per workflow
// key (see lib/workflow-registry.ts); absence of a row means "enabled with
// default settings". `settings` holds the workflow's tunable values as JSON,
// merged over the registry defaults at read time (lib/workflow-config.ts).
model WorkflowConfig {
  id          String   @id @default(cuid())
  workflowKey String   @unique
  enabled     Boolean  @default(true)
  settings    Json     @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Module-level RBAC. Each row grants one Neon Auth user (neon_auth.user, keyed
// by id like NotificationSettings/PortalUser — deliberately not a Prisma
// relation) access to one module. The module key set lives in lib/modules.ts
// (MODULE_REGISTRY). Admins bypass this table entirely; absence of a row means
// no access for non-admin users.
model UserModuleAccess {
  id         String   @id @default(cuid())
  authUserId String
  module     String
  createdAt  DateTime @default(now())

  @@unique([authUserId, module])
  @@index([authUserId])
}
